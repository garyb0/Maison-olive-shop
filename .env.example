DATABASE_URL="file:../maison-olive-data/db/dev.db"

# Session security
SESSION_SECRET="change-me-with-a-long-random-secret"
SESSION_COOKIE_NAME="chezolive_session"
SESSION_DURATION_DAYS="30"

# Business rules
TAX_RATE="0.14975"
SHIPPING_FLAT_CENTS="899"
SHIPPING_FREE_THRESHOLD_CENTS="7500"

# Public URLs and browser-visible keys
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Proxy trust model: use cloudflare only behind Cloudflare, otherwise none.
APP_TRUST_PROXY="none"

# Meta Messenger Send Dialog (optional)
NEXT_PUBLIC_FACEBOOK_APP_ID=""
NEXT_PUBLIC_FACEBOOK_SEND_REDIRECT_URL="http://localhost:3000/boutique"

# Google sign-in (optional)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Delivery experiments
# Keep false on the live storefront until the new delivery workflow is validated.
DELIVERY_EXPERIMENTAL_ROUTING_ENABLED="false"
DELIVERY_GPS_TRACKING_ENABLED="false"
GOOGLE_MAPS_API_KEY=""
DELIVERY_DEPOT_LABEL="Chez Olive"
DELIVERY_DEPOT_LINE1=""
DELIVERY_DEPOT_CITY="Rimouski"
DELIVERY_DEPOT_REGION="QC"
DELIVERY_DEPOT_POSTAL=""
DELIVERY_DEPOT_COUNTRY="CA"

# Stripe (optional; leave blank for manual payment mode)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
ALLOW_STRIPE_TEST_KEYS_IN_PRODUCTION="false"

# Support / business
BUSINESS_SUPPORT_EMAIL="support@chezolive.ca"
ADMIN_SMS_EMAIL=""

# Customer transactional SMS via Twilio (optional)
SMS_NOTIFICATIONS_ENABLED="false"
SMS_DRY_RUN="true"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""

# Support AI (optional)
SUPPORT_AI_ENABLED="false"
SUPPORT_AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_SUPPORT_MODEL="gpt-5-mini"

# Transactional email: Resend or SMTP
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Chez Olive <onboarding@resend.dev>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""

# Web Push notifications (optional)
WEB_PUSH_PUBLIC_KEY=""
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:support@chezolive.ca"
WEB_PUSH_ALLOWED_HOSTS=""

# Android native push via Firebase Cloud Messaging (optional)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Health endpoint detail token (optional)
HEALTHCHECK_DETAIL_TOKEN=""
APP_RELEASE=""

# HomeCore private read-only integration
HOMECORE_INTERNAL_TOKEN=""
