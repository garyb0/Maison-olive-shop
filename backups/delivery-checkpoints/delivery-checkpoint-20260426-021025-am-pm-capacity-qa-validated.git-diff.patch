+  border-color: var(--brand);
+  color: #fff;
+}
+
+/* Icône ✕ en CSS pur */
+.nav-drawer-close-icon {
+  position: relative;
+  display: block;
+  width: 14px;
+  height: 14px;
+}
+
+.nav-drawer-close-icon::before,
+.nav-drawer-close-icon::after {
+  content: "";
+  position: absolute;
+  top: 50%;
+  left: 0;
+  width: 14px;
+  height: 2px;
+  background: currentColor;
+  border-radius: 2px;
+  transition: background 0.2s ease;
+}
+
+.nav-drawer-close-icon::before {
+  transform: translateY(-50%) rotate(45deg);
+}
+
+.nav-drawer-close-icon::after {
+  transform: translateY(-50%) rotate(-45deg);
+}
+
+/* Zone des liens */
+.nav-drawer-links {
+  flex: 1;
+  display: flex;
+  flex-direction: column;
+  padding: 0.6rem 0;
