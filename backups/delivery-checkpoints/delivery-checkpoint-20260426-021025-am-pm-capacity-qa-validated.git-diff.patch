+}
+
+/* Délais staggerés pour chaque lien */
+.nav-drawer--open .nav-drawer-links > .nav-drawer-link:nth-child(1) { animation-delay: 0.06s; }
+.nav-drawer--open .nav-drawer-links > .nav-drawer-link:nth-child(2) { animation-delay: 0.10s; }
+.nav-drawer--open .nav-drawer-links > .nav-drawer-link:nth-child(3) { animation-delay: 0.14s; }
+.nav-drawer--open .nav-drawer-links > .nav-drawer-link:nth-child(4) { animation-delay: 0.18s; }
+.nav-drawer--open .nav-drawer-links > .nav-drawer-link:nth-child(5) { animation-delay: 0.22s; }
+.nav-drawer--open .nav-drawer-links > .nav-drawer-link:nth-child(6) { animation-delay: 0.26s; }
+.nav-drawer--open .nav-drawer-links > .nav-drawer-link:nth-child(7) { animation-delay: 0.30s; }
