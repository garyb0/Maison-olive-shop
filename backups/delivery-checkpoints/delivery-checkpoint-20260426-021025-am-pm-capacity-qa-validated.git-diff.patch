+/* ─────────────────────────────────────────────────────────────────
+   Power Logout Button — Corner Breakout Design
+───────────────────────────────────────────────────────────────── */
+
+.nav-logout-inline {
+  position: relative;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 1.55rem;
+  height: 1.55rem;
+  border: 1.5px solid rgba(100, 116, 139, 0.2);
+  background: #ffffff;
+  color: #b0b8c4;
+  border-radius: 50%;
+  cursor: pointer;
+  font-family: inherit;
+  overflow: visible;
+  isolation: isolate;
+  box-shadow:
+    0 2px 8px rgba(15, 23, 42, 0.08),
+    0 1px 2px rgba(15, 23, 42, 0.04);
+  transition:
+    color 0.25s ease,
+    border-color 0.25s ease,
+    background 0.25s ease,
+    box-shadow 0.25s ease,
+    transform 0.2s ease;
+}
+
+/* Hover: red glow */
+.nav-logout-inline:hover:not(:disabled) {
+  color: #ef4444;
+  border-color: rgba(239, 68, 68, 0.35);
+  background: #fff5f5;
+  transform: scale(1.12);
+  box-shadow:
+    0 0 0 3px rgba(239, 68, 68, 0.1),
+    0 4px 14px rgba(239, 68, 68, 0.2);
+}
+
+/* Active: press */
+.nav-logout-inline:active:not(:disabled) {
+  transform: scale(0.94);
+  box-shadow:
+    0 0 0 2px rgba(239, 68, 68, 0.12),
+    0 1px 4px rgba(15, 23, 42, 0.08);
+}
+
+/* Focus-visible */
+.nav-logout-inline:focus-visible {
+  outline: none;
+  color: #ef4444;
+  border-color: rgba(239, 68, 68, 0.4);
+  box-shadow:
+    0 0 0 3px rgba(239, 68, 68, 0.16),
+    0 3px 10px rgba(15, 23, 42, 0.08);
+}
+
+/* Disabled */
+.nav-logout-inline:disabled {
+  opacity: 0.45;
+  cursor: not-allowed;
+}
+
+/* ── Power icon (CSS-only) ── */
+.nav-logout-inline-icon {
+  position: relative;
+  z-index: 1;
+  width: 0.78rem;
+  height: 0.78rem;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  font-size: 0;
+  line-height: 0;
+}
+
+/* Arc (open circle) */
+.nav-logout-inline-icon::before {
+  content: "";
+  position: absolute;
+  inset: 0.02rem;
+  border: 1.8px solid currentColor;
+  border-top-color: transparent;
+  border-radius: 50%;
+  transform: rotate(0deg);
+  transition: transform 0.3s ease;
+}
+
+.nav-logout-inline:hover:not(:disabled) .nav-logout-inline-icon::before {
+  transform: rotate(180deg);
+}
+
+/* Vertical bar (power stem) */
+.nav-logout-inline-icon::after {
+  content: "";
+  position: absolute;
+  top: -0.04rem;
+  left: 50%;
+  width: 1.8px;
+  height: 0.42rem;
+  background: currentColor;
+  border-radius: 999px;
+  transform: translateX(-50%);
+  transition: box-shadow 0.3s ease;
+}
+
+.nav-logout-inline:hover:not(:disabled) .nav-logout-inline-icon::after {
+  box-shadow: 0 0 8px rgba(239, 68, 68, 0.45);
+}
+
+/* Loading animation */
+.nav-logout-inline:disabled .nav-logout-inline-icon {
+  animation: nav-logout-pulse 1.1s ease-in-out infinite;
+}
+
+/* ── Tooltip ── */
+.nav-logout-inline-tooltip {
+  position: absolute;
+  top: calc(100% + 0.45rem);
+  right: 50%;
+  transform: translateX(50%) translateY(-4px) scale(0.92);
+  opacity: 0;
+  pointer-events: none;
+  background: #1e293b;
+  color: #fff;
+  border-radius: 0.45rem;
+  padding: 0.22rem 0.55rem;
+  font-size: 0.68rem;
+  font-weight: 600;
+  letter-spacing: 0.01em;
+  white-space: nowrap;
+  box-shadow: 0 4px 12px rgba(15, 23, 42, 0.22);
+  transition: opacity 0.2s ease, transform 0.2s ease;
+  z-index: 50;
+}
+
+/* Tooltip arrow — points up */
+.nav-logout-inline-tooltip::after {
+  content: "";
+  position: absolute;
+  bottom: 100%;
+  right: 50%;
+  width: 0.4rem;
+  height: 0.4rem;
+  background: #1e293b;
+  transform: translate(50%, 55%) rotate(45deg);
+  border-radius: 1px;
+}
+
+/* Show tooltip on hover/focus */
