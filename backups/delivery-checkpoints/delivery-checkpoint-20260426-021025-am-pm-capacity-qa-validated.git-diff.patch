+/* ─────────────────────────────────────────────────────────────────
+   Premium Glow Border — Header, Banner, Product Cards
+   CSS only · pseudo-element ::before · animation subtile
+───────────────────────────────────────────────────────────────── */
+
+/* Classe commune à appliquer aux éléments ciblés */
+.glow-border {
+  position: relative;
+  isolation: isolate;
+}
+
+/* Pseudo-element : bordure lumineuse animée */
+.glow-border::before {
+  content: "";
+  position: absolute;
+  inset: -1.5px;
+  border-radius: inherit;
+  padding: 1.5px;
+  background: linear-gradient(
+    135deg,
+    rgba(92, 107, 64, 0.6) 0%,
+    rgba(143, 160, 94, 0.8) 25%,
+    rgba(196, 149, 90, 0.9) 50%,
+    rgba(143, 160, 94, 0.8) 75%,
+    rgba(92, 107, 64, 0.6) 100%
+  );
+  background-size: 300% 300%;
+  -webkit-mask:
+    linear-gradient(#fff 0 0) content-box,
+    linear-gradient(#fff 0 0);
+  -webkit-mask-composite: xor;
+  mask-composite: exclude;
+  z-index: -1;
+  opacity: 0;
+  animation: glow-border-shift 6s ease-in-out infinite,
+             glow-border-fade-in 0.8s ease forwards;
+  pointer-events: none;
+}
+
+/* Animation : défilement lent du dégradé */
+@keyframes glow-border-shift {
+  0%   { background-position: 0% 50%; }
+  50%  { background-position: 100% 50%; }
+  100% { background-position: 0% 50%; }
+}
+
+/* Animation : apparition douce au chargement */
+@keyframes glow-border-fade-in {
+  from { opacity: 0; }
+  to   { opacity: 1; }
+}
+
+/* Hover : intensification subtile */
+.glow-border:hover::before {
+  opacity: 1;
+  animation: glow-border-shift 4s ease-in-out infinite;
+}
+
+/* Desktop: masquer le hamburger et le bloc mobile-right */
+@media (min-width: 761px) {
+  .nav-hamburger {
+    display: none !important;
+  }
+  .nav-mobile-right {
+    display: none !important;
+  }
+}
+
+/* Mobile: caché par défaut — le drawer prend le relais */
+@media (max-width: 760px) {
+  .nav-body {
+    display: none !important;
+  }
+}
+
+/* ─────────────────────────────────────────────────────────────────
+   Mobile — bloc panier + hamburger dans le header
+───────────────────────────────────────────────────────────────── */
+
+.nav-mobile-right {
+  display: none; /* affiché seulement sur mobile via media query ci-dessus */
+  align-items: center;
+  gap: 0.5rem;
+  margin-left: auto;
+}
+
+@media (max-width: 760px) {
+  .nav-mobile-right {
+    display: flex;
+  }
+
+  /* Le hamburger dans le wrapper ne doit plus avoir margin-left: auto */
+  .nav-mobile-right .nav-hamburger {
+    margin-left: 0;
+  }
+}
+
+/* ─────────────────────────────────────────────────────────────────
+   Drawer latéral mobile
+───────────────────────────────────────────────────────────────── */
+
+/* Overlay sombre derrière le drawer */
+.nav-drawer-overlay {
+  position: fixed;
+  inset: 0;
+  background: rgba(44, 30, 15, 0.5);
+  backdrop-filter: blur(3px);
+  -webkit-backdrop-filter: blur(3px);
+  z-index: 998;
+  opacity: 0;
+  pointer-events: none;
+  transition: opacity 0.32s ease;
+}
+
+.nav-drawer-overlay--visible {
+  opacity: 1;
+  pointer-events: all;
+}
+
+/* Drawer principal */
+.nav-drawer {
+  position: fixed;
+  top: 0;
+  left: 0;
+  width: min(82vw, 300px);
+  height: 100dvh;
