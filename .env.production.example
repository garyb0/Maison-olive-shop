NODE_ENV=production

# Base de données (production)
# Ne pas utiliser dev.db en vrai. Garder prod.db hors du dossier du code.
# Preparé par: npm run release:prepare-data-root
# Exemple local serveur:
# CHEZOLIVE_DATA_ROOT="../maison-olive-data"
# CHEZOLIVE_BACKUP_DIR="../maison-olive-data/backups"
# CHEZOLIVE_LOG_DIR="../maison-olive-data/logs"
# CHEZOLIVE_SECRETS_FILE="../maison-olive-data/secrets/chez-olive.production.env"
# DATABASE_URL="file:../maison-olive-data/db/prod.db"
# Exemple DB gérée:
# DATABASE_URL="libsql://.../?authToken=..."
CHEZOLIVE_DATA_ROOT=""
CHEZOLIVE_BACKUP_DIR=""
CHEZOLIVE_LOG_DIR=""
CHEZOLIVE_SECRETS_FILE=""
DATABASE_URL=""

# Sessions / auth
# 32+ caractères obligatoires
SESSION_SECRET=""
SESSION_COOKIE_NAME="chezolive_session"
SESSION_DURATION_DAYS="30"

# Business rules
TAX_RATE="0.14975"
SHIPPING_FLAT_CENTS="899"
SHIPPING_FREE_THRESHOLD_CENTS="7500"

# URL publique
# Domaine final du site
# Exemple: https://chezolive.ca
NEXT_PUBLIC_SITE_URL="https://example.com"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Meta Messenger Send Dialog (optionnel)
# Creer une app Meta Developer, autoriser chezolive.ca, puis rebuild.
NEXT_PUBLIC_FACEBOOK_APP_ID=""
NEXT_PUBLIC_FACEBOOK_SEND_REDIRECT_URL="https://chezolive.ca/boutique"

# Connexion Google (optionnel)
# Creer un OAuth Client Web dans Google Cloud Console.
# Redirect URI prod: https://chezolive.ca/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="https://chezolive.ca/api/auth/google/callback"

# Delivery experiments
# Garder false tant que le nouveau moteur de livraison n'a pas ete valide.
DELIVERY_EXPERIMENTAL_ROUTING_ENABLED="false"
DELIVERY_GPS_TRACKING_ENABLED="false"
GOOGLE_MAPS_API_KEY=""
DELIVERY_DEPOT_LABEL="Chez Olive"
DELIVERY_DEPOT_LINE1=""
DELIVERY_DEPOT_CITY="Rimouski"
DELIVERY_DEPOT_REGION="QC"
DELIVERY_DEPOT_POSTAL=""
DELIVERY_DEPOT_COUNTRY="CA"

# Stripe (laisser vide si mode paiement manuel)
# Pré-prod possible avec clés test si override explicite:
# ALLOW_STRIPE_TEST_KEYS_IN_PRODUCTION="true"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
ALLOW_STRIPE_TEST_KEYS_IN_PRODUCTION="false"

# Support
BUSINESS_SUPPORT_EMAIL="support@chezolive.ca"
ADMIN_SMS_EMAIL=""

# SMS transactionnels clients via Twilio (activer apres test reel)
SMS_NOTIFICATIONS_ENABLED="false"
SMS_DRY_RUN="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""

# Support AI (optionnel)
SUPPORT_AI_ENABLED="false"
SUPPORT_AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_SUPPORT_MODEL="gpt-5-mini"

# Email transactionnel: Resend ou SMTP
# Utiliser un domaine/expéditeur vérifié, pas onboarding@resend.dev en prod.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Chez Olive <noreply@chezolive.ca>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""

# Web Push navigateur (optionnel)
WEB_PUSH_PUBLIC_KEY=""
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:support@chezolive.ca"

# Push natif Android (Firebase Cloud Messaging)
# FIREBASE_PRIVATE_KEY doit conserver les sauts de ligne sous forme \n si stockee dans un fichier .env.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Health detail et integration interne (optionnels)
HEALTHCHECK_DETAIL_TOKEN=""
APP_RELEASE=""
HOMECORE_INTERNAL_TOKEN=""
