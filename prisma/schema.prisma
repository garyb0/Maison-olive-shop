// CRITICAL DATA SAFETY NOTE (FR/EN)
// FR: Ne jamais supprimer ou altérer de façon destructive les données commandes/inventaire/utilisateurs.
// EN: Never destructively delete or alter orders/inventory/user data.
// Use soft workflows, audit logs, and transactions for critical mutations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MANUAL
  STRIPE
}

enum ConversionEventType {
  SHOP_VIEW
  PRODUCT_VIEW
  CART_ADD
  CART_VIEW
  CHECKOUT_START
  DELIVERY_SELECTED
  PAYMENT_SELECTED
  ORDER_CREATED
  CHECKOUT_ERROR
}

enum DeliveryStatus {
  UNSCHEDULED
  SCHEDULED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RESCHEDULED
}

enum DeliveryRunStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DeliveryStopStatus {
  PENDING
  DELIVERED
  FAILED
}

enum ActualKmSource {
  GPS
  ODOMETER
  MANUAL_ADMIN
}

enum SupportConversationStatus {
  WAITING
  OPEN
  ASSIGNED
  CLOSED
}

enum SupportSenderType {
  CUSTOMER
  ADMIN
  SYSTEM
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  passwordHash              String?
  firstName                 String
  lastName                  String
  role                      UserRole  @default(CUSTOMER)
  language                  String    @default("fr")
  twoFactorEnabled          Boolean   @default(false)
  twoFactorSecretCiphertext String?
  twoFactorBackupCodesJson  String?
  twoFactorEnabledAt        DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  sessions                     Session[]
  oauthAccounts                OAuthAccount[]
  orders                       Order[]
  logs                         AuditLog[]
  customerSupportConversations SupportConversation[] @relation("CustomerSupportConversations")
  assignedSupportConversations SupportConversation[] @relation("AssignedSupportConversations")
  supportMessages              SupportMessage[]      @relation("SupportMessages")
  supportNotificationPreference SupportNotificationPreference?
  notificationPreference        NotificationPreference?
  supportInternalNotes          SupportInternalNote[]
  supportQuickReplies           SupportQuickReply[]
  passwordResets               PasswordReset[]
  subscriptions                Subscription[]
  subscriptionCheckoutIntents  SubscriptionCheckoutIntent[]
  deliveryAddresses            UserDeliveryAddress[]
  dogProfiles                  DogProfile[]
  dogQrScans                   DogQrScan[]
  webPushSubscriptions         WebPushSubscription[]
  nativePushTokens             NativePushToken[]
  appNotifications             AppNotification[]
  productFavorites             ProductFavorite[]
  smsRecipientPreferences      SmsRecipientPreference[]
  smsNotificationLogs          SmsNotificationLog[]
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
}

model DogProfile {
  id             String   @id @default(cuid())
  userId         String?
  publicToken    String   @unique
  name           String?
  photoUrl       String?
  ageLabel       String?
  ownerPhone     String?
  importantNotes String?
  publicProfileEnabled Boolean @default(true)
  showPhotoPublic      Boolean @default(false)
  showAgePublic        Boolean @default(false)
  showPhonePublic      Boolean @default(false)
  showNotesPublic      Boolean @default(false)
  lostModeEnabled      Boolean @default(false)
  lostModeMessage      String?
  lostModeActivatedAt  DateTime?
  isActive       Boolean  @default(true)
  claimedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  dogQrScans DogQrScan[]

  @@index([userId, createdAt])
  @@index([publicToken, isActive])
}

model DogQrScan {
  id              String   @id @default(cuid())
  dogId           String
  viewerUserId    String?
  eventType       String   @default("VIEW")
  lostModeAtScan  Boolean  @default(false)
  latitude        Float?
  longitude       Float?
  accuracyMeters  Float?
  locationSharedAt DateTime?
  userAgent       String?
  ipHash          String?
  createdAt       DateTime @default(now())

  dog DogProfile @relation(fields: [dogId], references: [id], onDelete: Cascade)
  viewer User? @relation(fields: [viewerUserId], references: [id], onDelete: SetNull)

  @@index([dogId, createdAt])
  @@index([eventType, createdAt])
  @@index([viewerUserId, createdAt])
}

model UserDeliveryAddress {
  id                   String   @id @default(cuid())
  userId               String
  label                String
  shippingLine1        String
  shippingCity         String
  shippingRegion       String
  shippingPostal       String
  shippingCountry      String
  deliveryPhone        String?
  deliveryInstructions String?
  lastUsedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, lastUsedAt])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum SubscriptionInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
  EXPIRED
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  sku           String?  @unique
  barcode       String?  @unique
  nameFr        String
  nameEn        String
  descriptionFr String
  descriptionEn String
  imageUrl      String?
  priceCents    Int
  costCents     Int      @default(0)
  currency      String   @default("CAD")
  stock         Int      @default(0)
  isActive      Boolean  @default(true)
  
  // Subscription fields
  isSubscription Boolean              @default(false)
  
  // Multi frequency prices
  priceWeekly    Int?
  priceBiweekly  Int?
  priceMonthly   Int?
  priceQuarterly Int?
  
  stripePriceWeekly    String? @unique
  stripePriceBiweekly  String? @unique
  stripePriceMonthly   String? @unique
  stripePriceQuarterly String? @unique
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems          OrderItem[]
  inventoryMovements  InventoryMovement[]
  variants            ProductVariant[]
  categoryId          String?
  category            Category? @relation(fields: [categoryId], references: [id])
  subcategoryId       String?
  subcategory         ProductSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  subscriptions       Subscription[]
  subscriptionCheckoutIntents SubscriptionCheckoutIntent[]
  favoritedBy         ProductFavorite[]

  @@index([isActive])
  @@index([slug])
  @@index([categoryId])
  @@index([subcategoryId])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  slug          String
  sku           String   @unique
  barcode       String?  @unique
  colorNameFr   String?
  colorNameEn   String?
  colorHex      String?
  sizeNameFr    String?
  sizeNameEn    String?
  sizeCode      String?
  sizeSortOrder Int?
  imageUrl      String?
  stock         Int      @default(0)
  priceCents    Int?
  costCents     Int?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]

  @@unique([productId, slug])
  @@index([productId, isActive, sortOrder])
  @@index([productId, stock])
  @@index([sizeCode])
}

model ProductFavorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
  @@index([productId])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  customerEmail   String
  customerName    String
  promoCode       String?
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(MANUAL)
  paymentProvider String?
  stripeSessionId String?       @unique
  inventoryReservedAt DateTime?
  deliveryCapacityReservedAt DateTime?
  subtotalCents   Int
  discountCents   Int           @default(0)
  taxCents        Int
  shippingCents   Int
  refundedCents   Int           @default(0)
  totalCents      Int
  currency        String        @default("CAD")
  shippingLine1   String?
  shippingCity    String?
  shippingRegion  String?
  shippingPostal  String?
  shippingCountry String?
  deliverySlotId  String?
  deliveryWindowStartAt DateTime?
  deliveryWindowEndAt DateTime?
  deliveryStatus  DeliveryStatus @default(UNSCHEDULED)
  deliveryInstructions String?
  deliveryPhone   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  inventoryMovements InventoryMovement[]
  deliverySlot       DeliverySlot?       @relation(fields: [deliverySlotId], references: [id], onDelete: SetNull)
  deliveryStops      DeliveryStop[]
  supportConversations SupportConversation[]
  smsRecipientPreferences SmsRecipientPreference[]
  smsNotificationLogs     SmsNotificationLog[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([paymentStatus])
  @@index([deliverySlotId])
  @@index([deliveryStatus])
  @@index([promoCode])
}

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  discountPercent Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, code])
}

model DeliverySlot {
  id        String   @id @default(cuid())
  startAt   DateTime
  endAt     DateTime
  capacity  Int      @default(8)
  isOpen    Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  runs      DeliveryRun[]

  @@index([startAt])
  @@index([endAt])
  @@index([isOpen, startAt])
}

model DeliveryException {
  id               String   @id @default(cuid())
  dateKey          String   @unique
  isClosed         Boolean  @default(true)
  capacityOverride Int?
  reason           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([dateKey])
}

model DeliveryScheduleSettings {
  id                     String   @id @default("default")
  averageDeliveryMinutes Int      @default(30)
  blockMinutes           Int      @default(60)
  amEnabled              Boolean  @default(true)
  amStartMinute          Int      @default(540)
  amEndMinute            Int      @default(720)
  pmEnabled              Boolean  @default(true)
  pmStartMinute          Int      @default(780)
  pmEndMinute            Int      @default(1020)
  capacityMode           String   @default("ACTIVE_DRIVERS")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Driver {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs DeliveryRun[]

  @@index([isActive, name])
}

model DeliveryRun {
  id                   String            @id @default(cuid())
  deliverySlotId       String
  driverId             String
  status               DeliveryRunStatus @default(DRAFT)
  dateKey              String
  includeReturnToDepot Boolean           @default(true)
  plannedKm            Float?
  plannedDurationSec   Int?
  actualKmGps          Float?
  actualKmOdometer     Float?
  actualKmFinal        Float?
  actualKmSource       ActualKmSource?
  odometerStartKm      Float?
  odometerEndKm        Float?
  note                 String?
  startedAt            DateTime?
  completedAt          DateTime?
  publishedAt          DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  deliverySlot DeliverySlot             @relation(fields: [deliverySlotId], references: [id], onDelete: Restrict)
  driver       Driver                   @relation(fields: [driverId], references: [id], onDelete: Restrict)
  stops        DeliveryStop[]
  accessTokens DeliveryRunAccessToken[]
  gpsSamples   DeliveryGpsSample[]
  webPushSubscriptions WebPushSubscription[]
  appNotifications     AppNotification[]

  @@unique([deliverySlotId])
  @@index([driverId, dateKey])
  @@index([status, dateKey])
}

model DeliveryStop {
  id                       String             @id @default(cuid())
  runId                    String
  orderId                  String
  plannedSequence          Int
  manualSequence           Int?
  finalSequence            Int
  status                   DeliveryStopStatus @default(PENDING)
  plannedLegKm             Float?
  plannedCumulativeKm      Float?
  plannedLegDurationSec    Int?
  plannedEta               DateTime?
  actualCumulativeKmAtStop Float?
  arrivedAt                DateTime?
  arrivedLat               Float?
  arrivedLng               Float?
  arrivedAccuracyMeters    Float?
  arrivedDistanceMeters    Float?
  completedAt              DateTime?
  note                     String?
  proofPhotoPath           String?
  proofPhotoMime           String?
  proofPhotoSizeBytes      Int?
  proofPhotoUploadedAt     DateTime?
  proofPhotoLat            Float?
  proofPhotoLng            Float?
  proofPhotoAccuracyMeters Float?
  geocodedLat              Float?
  geocodedLng              Float?
  geocodedAt               DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  run   DeliveryRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  order Order       @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([runId, orderId])
  @@index([runId, finalSequence])
  @@index([orderId])
}

model DeliveryRunAccessToken {
  id           String   @id @default(cuid())
  runId        String
  tokenHash    String   @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  lastAccessAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  run DeliveryRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, expiresAt])
}

model DeliveryGpsSample {
  id             String   @id @default(cuid())
  runId          String
  recordedAt     DateTime
  lat            Float
  lng            Float
  accuracyMeters Float
  speedMps       Float?
  heading        Float?
  createdAt      DateTime @default(now())

  run DeliveryRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, recordedAt])
}

model WebPushSubscription {
  id              String   @id @default(cuid())
  userId          String?
  driverRunId     String?
  driverTokenHash String?
  endpointHash    String   @unique
  endpoint        String
  p256dh          String
  auth            String
  audience        String   @default("CUSTOMER")
  userAgent       String?
  enabled         Boolean  @default(true)
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  driverRun DeliveryRun? @relation(fields: [driverRunId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@index([driverRunId, enabled])
  @@index([audience, enabled])
}

model NativePushToken {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  token       String
  platform    String   @default("ANDROID")
  enabled     Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@index([platform, enabled])
}

model NotificationPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  pushEnabled      Boolean  @default(false)
  orderUpdates     Boolean  @default(true)
  deliveryUpdates  Boolean  @default(true)
  supportUpdates   Boolean  @default(true)
  dogQrUpdates     Boolean  @default(true)
  adminAlerts      Boolean  @default(true)
  driverRunUpdates Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppNotification {
  id           String    @id @default(cuid())
  userId       String?
  driverRunId  String?
  audience     String    @default("CUSTOMER")
  type         String
  title        String
  body         String
  href         String?
  metadataJson String?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  user      User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  driverRun DeliveryRun? @relation(fields: [driverRunId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([driverRunId, readAt, createdAt])
  @@index([audience, createdAt])
  @@index([type, createdAt])
}

model SmsRecipientPreference {
  id          String    @id @default(cuid())
  userId      String?
  orderId     String?
  phoneE164   String
  language    String    @default("fr")
  optedIn     Boolean   @default(false)
  optedOut    Boolean   @default(false)
  optInSource String
  optInAt     DateTime?
  optOutAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)
  logs SmsNotificationLog[]

  @@unique([orderId, phoneE164])
  @@index([userId])
  @@index([orderId])
  @@index([phoneE164, optedOut])
}

model SmsNotificationLog {
  id                    String    @id @default(cuid())
  eventKey              String    @unique
  type                  String
  orderId               String?
  userId                String?
  recipientPreferenceId String?
  toPhoneE164           String
  language              String    @default("fr")
  bodyPreview           String?
  status                String    @default("PENDING")
  dryRun                Boolean   @default(false)
  twilioMessageSid      String?   @unique
  twilioAccountSid      String?
  twilioMessagingServiceSid String?
  errorCode             String?
  errorMessage          String?
  attemptedAt           DateTime?
  sentAt                DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  recipientPreference SmsRecipientPreference? @relation(fields: [recipientPreferenceId], references: [id], onDelete: SetNull)

  @@index([orderId, type])
  @@index([userId, createdAt])
  @@index([toPhoneE164, createdAt])
  @@index([status, createdAt])
}

model SmsInboundMessage {
  id           String   @id @default(cuid())
  messageSid   String   @unique
  fromPhoneE164 String
  toPhoneE164   String?
  optOutType   String?
  bodyPreview  String?
  createdAt    DateTime @default(now())

  @@index([fromPhoneE164, createdAt])
  @@index([optOutType, createdAt])
}

model GeocodedAddressCache {
  id               String   @id @default(cuid())
  addressKey       String   @unique
  shippingLine1    String
  shippingCity     String
  shippingRegion   String
  shippingPostal   String
  shippingCountry  String
  formattedAddress String
  placeId          String?
  lat              Float
  lng              Float
  lastUsedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shippingPostal])
  @@index([updatedAt])
}

model OrderItem {
  id                    String   @id @default(cuid())
  orderId               String
  productId             String
  variantId             String?
  quantity              Int
  unitPriceCents        Int
  lineTotalCents        Int
  productNameSnapshotFr String
  productNameSnapshotEn String
  createdAt             DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model ConversionEvent {
  id              String              @id @default(cuid())
  type            ConversionEventType
  sessionKey      String
  userId          String?
  productId       String?
  productSlug     String?
  orderId         String?
  orderNumber     String?
  currency        String              @default("CAD")
  cartTotalCents  Int?
  itemCount       Int?
  quantity        Int?
  paymentMethod   String?
  deliveryMode    String?
  language        String?
  device          String?
  path            String?
  referrerPath    String?
  metadataJson    String?
  createdAt       DateTime            @default(now())

  @@index([type, createdAt])
  @@index([sessionKey, createdAt])
  @@index([userId, createdAt])
  @@index([productId, createdAt])
  @@index([orderId])
  @@index([createdAt])
}

model InventoryMovement {
  id             String   @id @default(cuid())
  productId      String
  variantId      String?
  orderId        String?
  quantityChange Int
  reason         String
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([productId, createdAt])
  @@index([variantId, createdAt])
  @@index([orderId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entity      String
  entityId    String
  metadata    String?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entity, createdAt])
  @@index([actorUserId, createdAt])
}

model StripeWebhookEvent {
  id             String   @id @default(cuid())
  stripeEventId  String   @unique
  stripeEventType String
  status         String   @default("received")
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

model SupportConversation {
  id              String                    @id @default(cuid())
  customerUserId  String?
  customerEmail   String
  customerName    String
  assignedAdminId String?
  orderId         String?
  status          SupportConversationStatus @default(WAITING)
  priority        String                    @default("NORMAL")
  source          String                    @default("WIDGET")
  tagsJson        String?
  aiSummary       String?
  aiIntent        String?
  closedReason    String?
  closedNote      String?
  reopenedAt      DateTime?
  priorityUpdatedAt DateTime?
  slaDueAt        DateTime?
  lastMessageAt   DateTime                  @default(now())
  closedAt        DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  customerUser  User?            @relation("CustomerSupportConversations", fields: [customerUserId], references: [id], onDelete: SetNull)
  assignedAdmin User?            @relation("AssignedSupportConversations", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  order         Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages      SupportMessage[]
  internalNotes SupportInternalNote[]

  @@index([customerUserId, createdAt])
  @@index([assignedAdminId, status])
  @@index([orderId])
  @@index([priority, status])
  @@index([source, createdAt])
  @@index([slaDueAt, status])
  @@index([status, lastMessageAt])
}

model SupportMessage {
  id             String            @id @default(cuid())
  conversationId String
  senderUserId   String?
  senderType     SupportSenderType
  content        String
  metadataJson    String?
  readAt         DateTime?
  createdAt      DateTime          @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser   User?               @relation("SupportMessages", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
}

model SupportNotificationPreference {
  id                        String   @id @default(cuid())
  adminUserId               String   @unique
  emailNewConversation      Boolean  @default(true)
  emailNewMessage           Boolean  @default(true)
  emailConversationAssigned Boolean  @default(true)
  emailDigest               String   @default("none")
  displayName               String?
  quickRepliesJson          String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  adminUser User @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([emailNewConversation])
  @@index([emailNewMessage])
  @@index([emailConversationAssigned])
}

model SupportInternalNote {
  id             String   @id @default(cuid())
  conversationId String
  adminUserId    String?
  content        String
  createdAt      DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  adminUser    User?               @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([adminUserId, createdAt])
}

model SupportQuickReply {
  id               String   @id @default(cuid())
  title            String
  content          String
  category         String   @default("general")
  language         String   @default("fr")
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdByAdmin User? @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([language, isActive, sortOrder])
  @@index([category, isActive])
  @@index([createdByAdminId, createdAt])
}

model Category {
  id            String               @id @default(uuid())
  name          String               @unique
  products      Product[]
  subcategories ProductSubcategory[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model ProductSubcategory {
  id         String    @id @default(uuid())
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug       String
  nameFr     String
  nameEn     String
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RateLimitBucket {
  id        String   @id
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

// promo banner bilingual content
model PromoBanner {
  id        String   @id @default(cuid())
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  badgeFr   String   @map("badge") @default("🔥 Offre limitée")
  badgeEn   String   @default("")
  titleFr   String   @map("title")
  titleEn   String   @default("")
  price1Fr  String   @map("price1") @default("1 pour 64,99 $")
  price1En  String   @default("")
  price2Fr  String   @map("price2") @default("🔥 2 pour seulement 100 $")
  price2En  String   @default("")
  point1Fr  String   @map("point1") @default("Ultra doux")
  point1En  String   @default("")
  point2Fr  String   @map("point2") @default("Lavable")
  point2En  String   @default("")
  point3Fr  String   @map("point3") @default("Approuvé par Olive")
  point3En  String   @default("")
  ctaTextFr String   @map("ctaText") @default("Magasiner →")
  ctaTextEn String   @default("")
  ctaLink   String   @default("/")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Subscription {
  id                String             @id @default(cuid())
  stripeSubscriptionId String          @unique
  userId            String
  productId         String
  status            SubscriptionStatus @default(ACTIVE)
  quantity          Int                @default(1)
  currentPeriodStart DateTime
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean            @default(false)
  canceledAt        DateTime?
  lastPaymentDate   DateTime?
  nextPaymentDate   DateTime?
  
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([nextPaymentDate])
}

model SubscriptionCheckoutIntent {
  id              String               @id @default(cuid())
  userId          String
  productId       String
  priceId         String
  interval        SubscriptionInterval
  quantity        Int
  amountCents     Int
  currency        String               @default("CAD")
  stripeSessionId String               @unique
  status          String               @default("PENDING")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product              @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([productId])
  @@index([status])
}



