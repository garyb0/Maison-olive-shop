# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/audit-output
/output

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.bundle

# maintenance lock file (état dynamique, ne pas versionner)
.maintenance-lock
logs/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next-dev*.log

# env files (can opt-in for committing if needed)
.env*
!.env.production.example
scripts/windows/cloudflare-ddns.env
cloudflared-config.yml
*.cloudflared.json
tools/cloudflared.exe

# local database files
/*.db
*.db
*.db-*
*.db.*
*.sqlite
*.sqlite3
*.db-journal
/backups/*.db
/backups/*.db.json
/backups/delivery-checkpoints/

