    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:mobile-solid": "playwright test src/e2e/mobile-solid.spec.ts src/e2e/pwa-app.spec.ts --project=chromium --output=test-results/playwright-mobile-solid",
    "test:e2e:delivery-solid": "playwright test src/e2e/driver-sandbox-copilot.spec.ts --project=chromium --output=test-results/playwright-delivery-solid",
    "test:e2e:driver-sandbox": "playwright test src/e2e/driver-sandbox-copilot.spec.ts --project=chromium",
    "test:e2e:driver-full-day": "playwright test src/e2e/driver-sandbox-copilot.spec.ts --project=chromium",
    "test:e2e:headed": "playwright test --headed",
    "delivery:checkpoint": "tsx scripts/delivery-checkpoint.ts",
    "delivery:rollback:plan": "tsx scripts/delivery-rollback-plan.ts",
    "delivery:preactivate": "tsx scripts/delivery-preactivate.ts",
    "delivery:verify": "npm run test:module:orders",
    "delivery:seed:demo": "node scripts/seed-delivery-runs-demo.cjs",
    "delivery:sandbox:setup": "node scripts/delivery-sandbox-setup.cjs",
    "delivery:sandbox:dev": "node scripts/delivery-sandbox-dev.cjs",
    "lint": "eslint",
    "validate:env:dev": "tsx scripts/validate-env.ts development",
    "validate:env:prod": "tsx scripts/validate-env.ts production",
    "validate": "npm run validate:env:dev && npm run lint && npm run build",
    "smoke": "tsx scripts/smoke-check.ts",
    "smoke:delivery": "tsx scripts/delivery-smoke.ts",
    "sms:smoke": "tsx scripts/sms-smoke.ts",
    "smoke:account": "tsx scripts/account-smoke.ts",
    "verify:prod": "tsx scripts/verify-prod.ts",
    "preopen:check": "tsx scripts/preopen-check.ts",
    "release:audit": "tsx scripts/release-audit.ts",
    "release:solid": "tsx scripts/release-solid.ts",
    "mail:check": "tsx scripts/check-private-email-dns.ts",
    "db:backup": "tsx scripts/db-backup.ts",
    "db:backup:daily": "tsx scripts/db-backup-daily.ts",
    "db:backup:hourly": "tsx scripts/db-backup-hourly.ts",
    "db:backup:health": "tsx scripts/db-backup-health.ts --env=production",
    "db:clean-test-data": "tsx scripts/clean-prod-test-data.ts",
    "ops:status": "tsx scripts/ops-status.ts",
    "ops:backup-hourly:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/install-db-backup-hourly-hidden.ps1",
    "ops:backup-hourly:diagnose": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/diagnose-db-backup-hourly.ps1",
    "db:restore": "tsx scripts/db-restore.ts",
    "release:prepare-data-root": "tsx scripts/prepare-release-data-root.ts --env=production",
    "prisma:migrate:create": "prisma migrate dev --create-only",
    "prisma:migrate:safe": "tsx scripts/prisma-migrate-safe.ts",
    "host:pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "host:pm2:restart": "pm2 restart chez-olive-shop",
    "host:pm2:stop": "pm2 stop chez-olive-shop",
    "host:pm2:logs": "pm2 logs chez-olive-shop --lines 120",
    "host:pm2:status": "pm2 status",
    "host:pm2:save": "pm2 save",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "seed": "npm run prisma:seed",
    "site:close": "tsx scripts/site-maintenance.ts close",
    "site:open": "tsx scripts/site-maintenance.ts open",
    "site:status": "tsx scripts/site-maintenance.ts status"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
