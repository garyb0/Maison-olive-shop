{
  "name": "maison-olive-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3101",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start --hostname 0.0.0.0 --port 3101",
    "test": "vitest run",
    "test:maintenance": "vitest run src/tests/maintenance.test.ts src/tests/admin-maintenance-route.test.ts src/tests/auth-login-route.test.ts src/tests/orders-delivery-zone.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "validate:env:dev": "tsx scripts/validate-env.ts development",
    "validate:env:prod": "tsx scripts/validate-env.ts production",
    "validate": "npm run validate:env:dev && npm run lint && npm run build",
    "smoke": "tsx scripts/smoke-check.ts",
    "db:backup": "tsx scripts/db-backup.ts",
    "db:backup:daily": "tsx scripts/db-backup-daily.ts",
    "db:restore": "tsx scripts/db-restore.ts",
    "prisma:migrate:create": "prisma migrate dev --create-only",
    "prisma:migrate:safe": "tsx scripts/prisma-migrate-safe.ts",
    "host:pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "host:pm2:restart": "pm2 restart maison-olive-shop",
    "host:pm2:stop": "pm2 stop maison-olive-shop",
    "host:pm2:logs": "pm2 logs maison-olive-shop --lines 120",
    "host:pm2:status": "pm2 status",
    "host:pm2:save": "pm2 save",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "seed": "npm run prisma:seed",
    "site:close": "cross-env MAINTENANCE_MODE=true npm run host:pm2:restart",
    "site:open": "cross-env MAINTENANCE_MODE=false npm run host:pm2:restart",
    "site:status": "node -e \"console.log('Mode Maintenance:', process.env.MAINTENANCE_MODE === 'true' ? '🔴 FERMÉ' : '🟢 OUVERT')\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.2",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^18.4.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "pm2": "^6.0.14",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
