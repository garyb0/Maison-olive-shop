    "test:module:dogs": "vitest run src/tests/dog-public-page.test.tsx src/tests/account-dogs-client.test.tsx src/tests/account-dogs-route.test.ts src/tests/admin-dogs-route.test.ts src/tests/dog-token.test.ts src/tests/dog-claim-client.test.tsx src/tests/dog-qr-view-route.test.ts src/tests/dog-qr-location-route.test.ts",
    "test:module:orders": "vitest run src/tests/orders-delivery-zone.test.ts src/tests/orders-route.test.ts src/tests/order-confirmation-email.test.ts src/tests/delivery-mode.test.ts src/tests/delivery-slots-route.test.ts src/tests/delivery-address-dedup.test.ts src/tests/account-delivery-addresses-route.test.ts src/tests/admin-orders-delivery-status-route.test.ts src/tests/delivery-run-km.test.ts src/tests/delivery-runs-create-dynamic.test.ts src/tests/admin-delivery-runs-route.test.ts src/tests/admin-delivery-run-actions-route.test.ts src/tests/driver-run-route.test.ts src/tests/driver-run-actions-route.test.ts src/tests/driver-run-client-copy.test.tsx",
    "test:module:stripe": "vitest run src/tests/stripe-webhook-route.test.ts src/tests/stripe-order-payment.test.ts src/tests/subscription-checkout-route.test.ts src/tests/subscription-cancel-route.test.ts",
    "test:module:support": "vitest run src/tests/support-email-reply-route.test.ts src/tests/support-guest-token.test.ts",
    "test:module:admin": "vitest run src/tests/admin-api-guard.test.ts src/tests/admin-maintenance-route.test.ts src/tests/admin-images-route.test.ts src/tests/admin-products-privacy.test.ts src/tests/admin-product-form.test.tsx src/tests/admin-product-category-auto-create.test.ts src/tests/admin-product-stock-route.test.ts src/tests/admin-promo-route.test.ts src/tests/admin-promo-codes-route.test.ts src/tests/admin-dashboard-mobile-table.test.tsx src/tests/owner-dashboard-variant-stock.test.ts",
