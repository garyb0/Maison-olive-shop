{
  "name": "chez-olive-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3101",
    "dev:delivery": "next dev -p 3103",
    "build": "next build",
    "android:sync": "npm run build && tsx scripts/pm2-restart-if-running.ts chez-olive-shop && cap sync android",
    "android:build": "npm run android:sync && tsx scripts/android-gradle.ts assembleDebug",
    "android:bundle": "npm run android:sync && tsx scripts/android-gradle.ts bundleRelease",
    "android:doctor": "tsx scripts/android-doctor.ts",
    "android:screenshots": "playwright test src/e2e/play-store-screenshots.spec.ts --project=chromium --output=test-results/play-store-screenshots",
    "start": "next start --hostname 127.0.0.1 --port 3101",
    "start:lan": "next start --hostname 127.0.0.1 --port 3101",
    "test": "vitest run",
    "test:critical": "vitest run src/tests/maintenance.test.ts src/tests/admin-maintenance-route.test.ts src/tests/auth-login-route.test.ts src/tests/orders-delivery-zone.test.ts src/tests/subscription-checkout-route.test.ts src/tests/subscription-cancel-route.test.ts src/tests/stripe-webhook-route.test.ts",
